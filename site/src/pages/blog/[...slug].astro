---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import SketchDivider from "../../components/SketchDivider.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function fmtDate(d: Date): string {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const base = import.meta.env.BASE_URL;
---

<Base title={post.data.title} description={post.data.excerpt}>
  <a href={base} class="back-link">← All posts</a>

  <article class="prose" style="margin-top: 2rem;">
    <div class="kicker" style="margin-bottom: 0.5rem;">{fmtDate(post.data.date)}</div>
    <h1>{post.data.title}</h1>
    {post.data.excerpt && (
      <p style="color: var(--ink-secondary); font-size: 18px; margin-top: 0.5rem; line-height: 1.6;">
        {post.data.excerpt}
      </p>
    )}

    <div style="margin: 1.5rem 0;">
      <SketchDivider />
    </div>

    <Content />

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="tags">
        {post.data.tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </article>
</Base>
