---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import SketchDivider from "../../components/SketchDivider.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith("/") ? base.slice(0, -1) : base;
const guideHref = `${cleanBase}/getting-started`;
function postHref(id: string): string {
  return `${cleanBase}/blog/${id}`;
}

function fmtDate(d: Date): string {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Base title="Docs · Bet Tracker" currentNav="blog">
  <header>
    <div class="kicker">Methodology & write-ups</div>
    <h1 class="display display-xl" style="margin-top: 0.5rem;">THE DOCS.</h1>
  </header>

  <div style="margin-top: 1.5rem;">
    <SketchDivider />
  </div>

  <p style="margin-top: 2rem; color: var(--ink-secondary); font-size: 16px; max-width: 640px;">
    Long-form explanations of the math behind every calculator in the Bet Tracker
    app. How to read the outputs, when each tool is the right one to reach for,
    and where the formulas come from.
  </p>

  <aside class="guide-callout">
    <div class="guide-callout-label">New here?</div>
    <div class="guide-callout-body">
      <p>
        The <a href={guideHref}>Getting Started guide</a> walks through
        installing the app, logging your first bet, and the pre-bet workflow
        through the calculators. Start there before the math write-ups.
      </p>
    </div>
  </aside>

  <ul class="post-list" style="margin-top: 2rem;">
    {posts.map((post) => (
      <li>
        <a href={postHref(post.id)}>
          <h2>{post.data.title}</h2>
          <div class="date">{fmtDate(post.data.date)}</div>
          {post.data.excerpt && <p class="excerpt">{post.data.excerpt}</p>}
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
  .guide-callout {
    margin-top: 2rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-card);
    border: 1.5px solid var(--ink-primary);
    border-radius: 14px;
  }
  .guide-callout-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-secondary);
    margin-bottom: 0.5rem;
  }
  .guide-callout-body p {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
  }
</style>
