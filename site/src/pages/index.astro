---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import SketchDivider from "../components/SketchDivider.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const base = import.meta.env.BASE_URL;
function postHref(id: string): string {
  const clean = base.endsWith("/") ? base.slice(0, -1) : base;
  return `${clean}/blog/${id}`;
}

function fmtDate(d: Date): string {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Base title="Bet Tracker Docs">
  <header>
    <div class="kicker">Methodology & write-ups</div>
    <h1 class="display display-xl" style="margin-top: 0.5rem;">THE DOCS.</h1>
  </header>

  <div style="margin-top: 1.5rem;">
    <SketchDivider />
  </div>

  <p style="margin-top: 2rem; color: var(--ink-secondary); font-size: 16px; max-width: 640px;">
    Long-form explanations of the math behind every calculator in the Bet Tracker
    app. How to read the outputs, when each tool is the right one to reach for,
    and where the formulas come from.
  </p>

  <ul class="post-list" style="margin-top: 2rem;">
    {posts.map((post) => (
      <li>
        <a href={postHref(post.id)}>
          <h2>{post.data.title}</h2>
          <div class="date">{fmtDate(post.data.date)}</div>
          {post.data.excerpt && <p class="excerpt">{post.data.excerpt}</p>}
        </a>
      </li>
    ))}
  </ul>
</Base>
